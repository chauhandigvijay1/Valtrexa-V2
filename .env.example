# =========================================================================
# VALTREXA-V2 / AI CAREER OS — ENVIRONMENT CONFIGURATION TEMPLATE
# =========================================================================
# Copy this file to '.env' and populate with your credentials.
#
# Variable                       Purpose                                         Required?  Category
# ------------------------------ ----------------------------------------------- ---------- ----------------
# VITE_SUPABASE_URL              Supabase endpoint URL (frontend)                 Yes        Frontend (VITE_)
# VITE_SUPABASE_PUBLISHABLE_KEY  Supabase publishable/anon key (frontend)         Yes        Frontend (VITE_)
# SUPABASE_URL                   Supabase endpoint URL (backend)                  Yes        Backend API
# SUPABASE_SERVICE_ROLE_KEY      Supabase service role key (admin)                Yes        Backend API
# SUPABASE_PUBLISHABLE_KEY       Supabase publishable key (backend SSR)           Yes        Backend SSR
# OPENROUTER_API_KEY             OpenRouter AI provider key                       Yes (Pref) AI Provider
# OPENROUTER_MODEL               Default OpenRouter LLM model                     Yes        AI Provider
# GROQ_API_KEY                   Groq AI provider key (alternative)               No         AI Provider
# GROQ_MODEL                     Default Groq LLM model                           No         AI Provider
# GEMINI_API_KEY                 Gemini AI provider key (future)                  No         AI Provider
# GEMINI_MODEL                   Default Gemini LLM model                         No         AI Provider
# REDIS_URL                      Redis connection string for BullMQ queues        Yes        Queue System
# COOKIE_ENCRYPTION_KEY          AES-256-GCM key for encrypting provider cookies  Yes        Security
# TELEGRAM_BOT_TOKEN             Telegram bot token for notifications              No         Notifications
# TELEGRAM_CHAT_ID               Telegram chat ID for delivery                    No         Notifications
# PUBLIC_URL                     Public deployment URL (webhooks, CORS)           No         Deployment
# FRONTEND_URL                   Frontend origin for CORS (separate from PUBLIC)  No         CORS
# GMAIL_CLIENT_ID                Gmail OAuth2 client ID for email outreach        No         Gmail
# GMAIL_CLIENT_SECRET            Gmail OAuth2 client secret                       No         Gmail
# GMAIL_REFRESH_TOKEN            Gmail OAuth2 refresh token                       No         Gmail
# GMAIL_REDIRECT_URI             Gmail OAuth2 redirect URI                        No         Gmail
# EDGE_PATH                      Path to Microsoft Edge binary for Playwright     No         Browser Automation
# EDGE_USER_DATA_DIR             Directory for persistent Edge user data          No         Browser Automation
# EDGE_PROFILE_DIRECTORY         Profile directory inside User Data (Default)     No         Browser Automation
# PLAYWRIGHT_HEADLESS            Run Playwright in headless mode (true/false)     No         Browser Automation
# ENABLE_TELEGRAM_APPROVALS      Require Telegram approval before auto-apply      No         Feature Flag
# SENTRY_DSN                     Sentry DSN for error tracking                    No         Monitoring
# SENTRY_TRACES_SAMPLE_RATE      Sentry traces sample rate (0.0 - 1.0)            No         Monitoring
# RATE_LIMIT_WINDOW_MS           Rate limiter window in milliseconds              No         Rate Limiting
# RATE_LIMIT_MAX_REQUESTS        Max requests per window                          No         Rate Limiting
# ADMIN_EMAILS                   Comma-separated admin email addresses             No         Access Control
# LOG_LEVEL                      Logging level (debug/info/warn/error)            No         Logging
# NODE_ENV                       Node environment (development/production)        No         Runtime
# =========================================================================

# --- Application ---
NODE_ENV="development"

# --- Supabase Configuration ---
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# --- AI Providers ---
# At least one provider key (OPENROUTER_API_KEY or GROQ_API_KEY) is required.

# OpenRouter (primary)
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="openai/gpt-4o-mini"

# Groq (alternative)
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="llama3-8b-8192"

# Gemini (future / optional fallback)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-pro"

# --- Queue System (BullMQ / Redis) ---
REDIS_URL="rediss://default:<password>@<endpoint>.upstash.io:6379"

# --- Security / Encryption ---
# Key used to encrypt provider cookies at rest (AES-256-GCM, 32 bytes hex).
COOKIE_ENCRYPTION_KEY="your-32-byte-hex-encryption-key"

# --- Notifications (Telegram) ---
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# --- Deployment ---
PUBLIC_URL="https://your-app-domain.com"
FRONTEND_URL="https://your-frontend-domain.com"

# --- Gmail / Email Outreach (OAuth2) ---
GMAIL_CLIENT_ID="your-gmail-client-id"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_REFRESH_TOKEN="your-gmail-refresh-token"
GMAIL_REDIRECT_URI="http://localhost:4173/api/auth/gmail/callback"

# --- Playwright / Browser Automation ---
EDGE_PATH="C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe"
EDGE_USER_DATA_DIR="./edge-profile"
EDGE_PROFILE_DIRECTORY="Default"
PLAYWRIGHT_HEADLESS="true"

# --- Feature Flags ---
ENABLE_TELEGRAM_APPROVALS="false"

# --- Monitoring (Sentry) ---
SENTRY_DSN="your-sentry-dsn"
SENTRY_TRACES_SAMPLE_RATE="0.1"

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# --- Access Control ---
ADMIN_EMAILS="admin@example.com,admin2@example.com"

# --- Logging ---
LOG_LEVEL="info"
