# =========================================================================
# CAREER COMPASS PRO - ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# =========================================================================
# Copy this file to '.env' and populate with your credentials.
# Below is the catalog of environment variables used across the platform.
#
# Variable                       Purpose                                         Required?  Used By
# ------------------------------ ----------------------------------------------- ---------- ------------------
# VITE_SUPABASE_URL              Supabase endpoint URL                           Yes        Frontend client
# VITE_SUPABASE_PUBLISHABLE_KEY  Supabase publishable key                        Yes        Frontend client
# SUPABASE_URL                   Supabase endpoint URL (Admin/Backend)           Yes        Backend API, tests
# SUPABASE_SERVICE_ROLE_KEY      Supabase admin bypass key                       Yes        Backend API, tests
# SUPABASE_PUBLISHABLE_KEY       Supabase key for backend testing                Yes        Integration tests
# OPENROUTER_API_KEY             OpenRouter AI provider authorization key        Yes (Pref) OpenRouter client
# OPENROUTER_MODEL               Default OpenRouter LLM model                    Yes        OpenRouter client
# GROQ_API_KEY                   Groq AI provider authorization key              Yes (Pref) Groq client
# GROQ_MODEL                     Default Groq LLM model                          Yes        Groq client
# TELEGRAM_BOT_TOKEN             Bot token for status notifications              No         Telegram service
# TELEGRAM_CHAT_ID               Chat identifier for notification delivery       No         Telegram service
# GMAIL_CLIENT_ID                OAuth2 Client ID for email outreach             No         Gmail provider
# GMAIL_CLIENT_SECRET            OAuth2 Client Secret for email outreach         No         Gmail provider
# GMAIL_REFRESH_TOKEN            OAuth2 Refresh Token for offline access         No         Gmail provider
# GMAIL_REDIRECT_URI             OAuth2 Redirect URI configuration               No         Gmail provider
# N8N_WEBHOOK_URL                Target endpoint for workflow execution          No         n8n automation
# N8N_API_KEY                    API Key to authenticate with n8n instance       No         n8n automation
# PLAYWRIGHT_TEST_BASE_URL       Base URL for executing Playwright E2E tests     No         Playwright runner
# LINKEDIN_COOKIE                Session cookie for LinkedIn scraping/import     No         LinkedIn source
# LINKEDIN_API_KEY               API Key for LinkedIn oauth/integrations         No         LinkedIn source
# WELLFOUND_COOKIE               Session cookie for Wellfound scraping/import    No         Wellfound source
# WELLFOUND_API_KEY              API Key for Wellfound integrations              No         Wellfound source
# GREENHOUSE_API_KEY             Harvest API Key for Greenhouse job boards       No         Greenhouse import
# GREENHOUSE_BOARD_TOKEN         Public board token for Greenhouse job retrieval  No         Greenhouse import
# LEVER_API_KEY                  Partner API Key for Lever ATS                   No         Lever import
# LEVER_SITE_TOKEN               Lever site identifier token                     No         Lever import
# ASHBY_API_KEY                  API Key for Ashby job boards                    No         Ashby import
# WORKABLE_API_KEY               API Key for Workable job boards                 No         Workable import
# INDEED_COOKIE                  Session cookie for Indeed scraping/import       No         Indeed source
# INDEED_API_KEY                 API Key for Indeed integrations                 No         Indeed source
# NAUKRI_COOKIE                  Session cookie for Naukri scraping/import       No         Naukri source
# INSTAHYRE_COOKIE               Session cookie for Instahyre scraping/import     No         Instahyre source
# =========================================================================

# --- Supabase Configuration ---
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"

# --- AI Providers ---
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="openai/gpt-4o-mini"
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="llama3-8b-8192"

# --- Notifications ---
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# --- Gmail OAuth Integration ---
GMAIL_CLIENT_ID="your-gmail-client-id"
GMAIL_CLIENT_SECRET="your-gmail-client-secret"
GMAIL_REFRESH_TOKEN="your-gmail-refresh-token"
GMAIL_REDIRECT_URI="http://localhost:4173/api/auth/gmail/callback"

# --- N8N Automation ---
N8N_WEBHOOK_URL="https://n8n.yourdomain.com/webhook/some-id"
N8N_API_KEY="your-n8n-api-key"

# --- Playwright E2E Testing ---
PLAYWRIGHT_TEST_BASE_URL="http://localhost:4173"

# --- Job Boards & ATS Integrations ---
LINKEDIN_COOKIE="li_at=your-linkedin-li-at-cookie-value"
LINKEDIN_API_KEY="your-linkedin-api-key"

WELLFOUND_COOKIE="your-wellfound-cookie-value"
WELLFOUND_API_KEY="your-wellfound-api-key"

GREENHOUSE_API_KEY="your-greenhouse-harvest-key"
GREENHOUSE_BOARD_TOKEN="your-greenhouse-board-token"

LEVER_API_KEY="your-lever-api-key"
LEVER_SITE_TOKEN="your-lever-site-token"

ASHBY_API_KEY="your-ashby-api-key"
WORKABLE_API_KEY="your-workable-api-key"

INDEED_COOKIE="your-indeed-cookie-value"
INDEED_API_KEY="your-indeed-api-key"

NAUKRI_COOKIE="your-naukri-cookie-value"
INSTAHYRE_COOKIE="your-instahyre-cookie-value"

# --- General Server ---
PORT=4173
SESSION_SECRET="your-session-secret-key"
